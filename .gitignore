# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Data outputs (grandes, nao versionar)
data/*
data/.cockpit_cache/
# EXCEPTION: refactor baselines (small, must be versioned for regression tests)
!data/refactor_baseline/
!data/refactor_baseline/**
# EXCEPTION: archived validation artifacts remain versioned as audit evidence
!data/_archive/
data/_archive/*
!data/_archive/research/
data/_archive/research/*
!data/_archive/research/validation/
!data/_archive/research/validation/**
# EXCEPTION: core/data/ is a Python subpackage, not a data output dir
!core/data/
!core/data/**
core/data/__pycache__/
core/data/__pycache__/**

# Logs
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Keys & credentials — NUNCA versionar
config/keys.json
config/keys.json.enc
config/connections.json
config/vps.json
config/vpn.json

# Egg / editable install
*.egg-info/

# Node
node_modules/
.env

# PyInstaller
build/
dist/
*.spec

# Git worktrees (isolated Claude Code sessions)
.worktrees/

# Claude Code superpowers runtime
.superpowers/

# Claude Code local runtime (lockfiles, settings locais, logs de sessao)
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/continuation_log.md

# Pytest temp dirs (geradas em runtime, nao versionar)
.pytest_cache/
.pytest_tmp/
.pytest_tmp_*/
.pytest_local_tmp/
.test_tmp/
tests/_tmp/
tests/_tmp_probe/
pytest-cache-files-*/
pytest-run-*/
pytest_tmp_local*/
/tmp*/

# Alchemy (ARBITRAGE) param files — generated at runtime, not versioned
config/alchemy_params.json
config/alchemy_params.json.reload

# Server website build artifacts (generated by vite build — never versioned)
server/website/dist/
.claude/ 

# === Virtual envs ===
.venv/
venv/
env/
ENV/

# === Linters & coverage ===
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# === Extras Python ===
.eggs/
*.egg
*.manifest

# === Jupyter ===
.ipynb_checkpoints/

# === Editor temp files ===
*.swp
*.swo
*~

# === AURUM screen metrics runtime ===
screen_metrics_*.json

